# Convex CMS Configuration
NUXT_CMS_API_URL=https://shiny-condor-497.convex.site
NUXT_CMS_TEAM_SLUG=demo-team

# API Keys (create in CMS Settings > API Keys with different access levels)
# Public key: Only sees published content (use for production sites)
NUXT_CMS_API_KEY_PUBLIC=gink_xxxxxxxx...

# Preview key: Sees preview + published content (use for staging/preview sites)
NUXT_CMS_API_KEY_PREVIEW=gink_xxxxxxxx...

# Which access level to use: "public" or "preview"
# Default: "preview" in dev mode, "public" in production
# NUXT_CMS_ACCESS_LEVEL=preview
