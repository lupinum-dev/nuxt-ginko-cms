{
  "name": "@lupinum/cms-nuxt",
  "type": "module",
  "version": "0.1.0",
  "description": "Nuxt module for consuming Convex CMS public API",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "bin": {
    "cms-nuxt": "./bin/cms-nuxt.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src/cli"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "build": "nuxt-module-build build",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "@nuxt/kit": "^4.3.0",
    "defu": "^6.1.4",
    "ofetch": "^1.5.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.0",
    "nuxt": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
