# Required: Server-side API key for Ginko CMS (never exposed to browser)
NUXT_GINKO_CMS_KEY=your-api-key-here

# Required: Base URL of your Ginko CMS instance
NUXT_GINKO_CMS_BASE=https://site.ginko-cms.com

# Optional: Default locale override
# NUXT_GINKO_CMS_LOCALE=en

# Optional: Convex URL for client-side search (exposed to browser)
# NUXT_PUBLIC_GINKO_CMS_CONVEX_URL=https://your-instance.convex.cloud

# Optional: Read-only search key for Convex (exposed to browser - must be read-only!)
# NUXT_PUBLIC_GINKO_CMS_SEARCH_KEY=your-read-only-search-key
